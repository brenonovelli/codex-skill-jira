#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BOOTSTRAP_SCRIPT="${SCRIPT_DIR}/jira_bootstrap.sh"

usage() {
  cat <<'EOF'
Usage:
  codex-jira [ISSUE] [jira_bootstrap flags...]

Examples:
  codex-jira VA-1462
  codex-jira VA-1462 --mode run --workspace current-folder --clone off
  codex-jira --issue-json /tmp/VA-1462.raw.json

Notes:
  - If ISSUE is omitted, jira_bootstrap interactive questions collect missing values.
  - All extra args are forwarded to jira_bootstrap.sh.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

ISSUE=""
if [[ $# -gt 0 && "${1}" != -* ]]; then
  ISSUE="$1"
  shift
fi

if [[ -n "${ISSUE}" ]]; then
  exec "${BOOTSTRAP_SCRIPT}" --issue "${ISSUE}" "$@"
fi

exec "${BOOTSTRAP_SCRIPT}" "$@"
